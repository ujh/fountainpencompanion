- content_for :title, "Ink descriptions"

= paginate @versions

- @versions.each do |version|
  - next unless version.item
  div class="cluster"
    div class="name"= link_to version.item.name, ink_path(version.item)
    div class='diff'
      - calculate_diffs(version).each do |entry|
        div class='diff-field'
          strong= entry[:label]
          - if entry[:type] == :color
            div class='diff-content' style="display: flex; align-items: center; gap: 8px;"
              div style="width: 37px; height: 37px; background-color:#{entry[:old_color]};"
              | →
              div style="width: 37px; height: 37px; background-color:#{entry[:new_color]};"
          - else
            pre class='diff-content'= entry[:diff]
      div class='timestamp'
        = time_ago_in_words(version.created_at)
        '  ago
      - user = User.find_by(id: version.whodunnit)
      - if user
          div class='user'
            ' by
            = link_to user.public_name, user_path(user)
            = patron_tiny(user)


= paginate @versions
