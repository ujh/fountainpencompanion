<p style="margin: 0 0 16px;">Hello <%= @resource.email %>!</p>

<p style="margin: 0 0 16px;">Your account has been locked due to an excessive number of unsuccessful sign in attempts.</p>

<p style="margin: 0 0 16px;">Click the button below to unlock your account:</p>

<%= render "layouts/mailer_button", url: unlock_url(@resource, unlock_token: @token), text: "Unlock my account" %>

<p style="margin: 0;">Thanks,<br />The Fountain Pen Capybara</p>
