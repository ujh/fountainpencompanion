<p>Hello <%= @resource.email %>!</p>

<p>You can login using the link below:</p>

<p><%= link_to "Log in to my account", magic_link_url(@resource, @scope_name => {email: @resource.email, token: @token, remember_me: @remember_me}) %></p>

<p>Note that the link will expire in <%= Devise.passwordless_login_within.inspect %>.</p>

<p>Thanks,</p>
<p>The Fountain Pen Capybara</p>

<hr />
<p>
  <%= link_to 'Fountain Pen Companion', 'https://fountainpencompanion.com' %>
  <br />
  <%= link_to 'Privacy Policy', 'https://www.fountainpencompanion.com/pages/privacy-policy' %>
</p>

<p>
  <img src="https://fountainpencompanion.com/images/capybara/capybara_square,w_200.png" alt="Fountain Pen Capybara" width="200" />
</p>
